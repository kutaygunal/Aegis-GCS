{
    "pluginPaths": ["./plugins", "C:/Program Files/Aegis/plugins"],
    "autostartPlugins": [
        "aegis.plugins.telemetry_hud",
        "aegis.plugins.alert_console",
        "aegis.plugins.mission_editor",
        "aegis.plugins.map_view"
    ],
    "telemetry": {
        "bindAddress": "0.0.0.0",
        "bindPort": 14550,
        "heartbeatTimeoutMs": 3000
    },
    "logging": {
        "minLevel": "Debug",
        "file": "aegis.log",
        "maxFiles": 5,
        "maxSizeBytes": 10485760
    },
    "dummyTelemetry": {
        "enabled": true,
        "intervalMs": 100
    },
    "plugins": {
        "aegis.plugins.telemetry_hud": {},
        "aegis.plugins.alert_console": {
            "maxItems": 250,
            "showTimestamps": true
        },
        "aegis.plugins.mission_editor": {},
        "aegis.plugins.map_view": {
            "zoom": 15,
            "tileUrlTemplate": "https://tile.openstreetmap.org/%1/%2/%3.png"
        }
    }
}
